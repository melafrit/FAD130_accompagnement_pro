# === Boussole — variables d'environnement (exemple) ===
# Copier en `.env` (sur le serveur) et remplir. NE JAMAIS committer le vrai .env.

# Domaine & reverse proxy de façade (VPS OVH)
DOMAIN=boussole.elafrit.com
APP_URL=https://boussole.elafrit.com   # base des liens emails ET origine CORS par défaut (dev : http://localhost:5173)
EDGE_NETWORK=formaplanner_formaplanner # réseau Docker du Caddy de façade auquel le front s'attache
NODE_ENV=production
# Origines autorisées pour CORS (liste séparée par des virgules). Si absent, dérivé d'APP_URL.
# En production, chaque origine DOIT être en HTTPS, sinon le démarrage échoue (fail-fast).
# ALLOWED_ORIGINS=https://boussole.elafrit.com

# Secrets — OBLIGATOIRE en production : générer un secret FORT (≥ 32 caractères).
#   openssl rand -hex 32
# Le démarrage échoue (exit 1) si JWT_SECRET est absent, < 32 caractères, ou laissé à « change_me ».
SESSION_SECRET=change_me
JWT_SECRET=change_me

# Anthropic (Claude) — clé UNIQUEMENT côté serveur, jamais dans Git
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_REALTIME=claude-sonnet-4-6
ANTHROPIC_MODEL_REPORT=claude-opus-4-8

# Emails (Brevo)
BREVO_API_KEY=
MAIL_FROM=contact@elafrit.com

# Comptes initiaux (seed au premier démarrage)
ADMIN_EMAIL=mohamed@elafrit.com
ACCOMPAGNATEUR_EMAIL=elafrit.mohamed@gmail.com
# Mot de passe de démo pour les comptes seed.
#  - VIDE  → production réelle : seuls admin + accompagnateur sont créés (activation par email), aucune donnée de démo.
#  - DÉFINI (ex. BoussoleDemo2026) → charge le JEU DE DÉMO complet (2 accompagnateurs, 3 accompagnés,
#    6 dossiers), réinitialisé à chaque démarrage. Idéal pour une démonstration / l'oral.
SEED_PASSWORD=

# Sécurité — rate limiting (anti brute-force) & CSRF. NE PAS désactiver en production :
# en NODE_ENV=production, la présence de l'une de ces variables à 1 EMPÊCHE le démarrage (fail-fast).
# RATE_LIMIT_DISABLED=1            # à 1 UNIQUEMENT en local/test (batterie de tests)
# CSRF_DISABLED=1                 # à 1 UNIQUEMENT en local/test (protection double-submit côté prod)
RATE_LIMIT_AUTH_MAX=30            # tentatives d'authentification par fenêtre (login/inscription/reset)
RATE_LIMIT_AUTH_WINDOW_MS=600000 # fenêtre du limiteur d'auth (10 min)
RATE_LIMIT_GLOBAL_MAX=600        # requêtes par minute et par IP (limiteur global)

# Sauvegardes locales de la base SQLite (sauvegarde « online » quotidienne + rétention)
BACKUP_RETENTION_DAYS=14         # nombre de jours de conservation
# BACKUP_DIR=./data/backups      # répertoire des sauvegardes (défaut)
# BACKUP_ENABLED=0               # mettre à 0 pour désactiver la planification
